# Robetta (used by test scripts)
ROBETTA_USERNAME=your_robetta_username
ROBETTA_PASSWORD=your_robetta_password

# QMEAN credentials (optional, if used by wrappers)
QMEAN_EMAIL=your_email@example.com
QMEAN_TOKEN=your_qmean_api_token

# MODELLER license key (if required by your environment)
MODELLER_KEY=your_modeller_key
